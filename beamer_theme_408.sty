\ProvidesPackage{beamer_theme_408}

% 408 考研零基础课程 Beamer 共用主题 v2.1
% 使用方法: \usepackage{beamer_theme_408}

% --- 主题与配色 ---
\usetheme{Madrid}
\usecolortheme{dolphin}

% --- 支持中文 ---
\usepackage{ctex}
\usepackage{xeCJK}
\setCJKmainfont{Noto Sans CJK SC}
\setCJKsansfont{Noto Sans CJK SC}
\setCJKmonofont{Noto Sans CJK SC}
\xeCJKsetup{PunctStyle=plain}

% --- 常用数学包 ---
\usepackage{amsmath, amssymb}
\usepackage{multirow}

% --- 代码展示 ---
\usepackage{listings}
\lstset{
    basicstyle=\ttfamily\small,
    language=C,
    showstringspaces=false,
    frame=single,
    breaklines=true
}

% --- 绘图 ---
\usepackage{tikz}
\usetikzlibrary{positioning,decorations.pathreplacing,decorations.pathmorphing,shapes.geometric,arrows.meta}
\usepackage{graphicx}

% --- 颜色定义 ---
\usepackage{xcolor}
\definecolor{408blue}{RGB}{0,82,164}
\definecolor{408orange}{RGB}{230,126,34}
\definecolor{primary}{HTML}{007AFF}
\definecolor{secondary}{HTML}{5856D6}
\definecolor{accent}{HTML}{FF9500}

% --- 导航栏（顶部小节圆点） ---
\setbeamertemplate{mini frames}[box]
\setbeamertemplate{navigation symbols}{}

% --- 页脚 ---
\setbeamertemplate{footline}{
    \leavevmode
    \hbox{%
        \begin{beamercolorbox}[wd=.38\paperwidth,ht=2.5ex,dp=1ex,center]{author in head/foot}%
            \usebeamerfont{author in head/foot}%
            \ifx\insertshorttitle\empty
                408考研零基础
            \else
                \insertshorttitle
            \fi
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.34\paperwidth,ht=2.5ex,dp=1ex,center]{section in head/foot}%
            \usebeamerfont{section in head/foot}%
            \ifx\insertsectionhead\empty
                \ifx\insertshortsubtitle\empty\else\insertshortsubtitle\fi
            \else
                \insertsectionhead
            \fi
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.28\paperwidth,ht=2.5ex,dp=1ex,right]{date in head/foot}%
            \usebeamerfont{date in head/foot}%
            \insertframenumber{} / \inserttotalframenumber\hspace*{2ex}
        \end{beamercolorbox}%
    }
    \vskip0pt
}

% --- 标题页 ---
\setbeamertemplate{title page}{
    \vfill
    \begin{centering}
        \vspace{1.5em}
        {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}
        \vspace{0.8em}
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}
        \vspace{1.5em}
        \begin{tikzpicture}[>=stealth]
            \node[draw=408blue,fill=408blue!5,rounded corners,inner sep=10pt] {
                \begin{minipage}{0.75\textwidth}
                    \centering
                    {\small\textbf{本节要点}\\[0.3em]
                    本讲将系统讲解核心知识点，配合例题巩固理解}
                \end{minipage}
            };
        \end{tikzpicture}
        \vspace{1em}
        \par
        {\small\textcolor{408blue}{408考研零基础系列课程}}
    \end{centering}
    \vfill
}

% --- 模块标题页（节） ---
\setbeamertemplate{section page}{
    \begin{centering}
        \vspace{1em}
        % 顶部装饰条
        \begin{tikzpicture}
            \fill[408blue] (0,0) rectangle (\paperwidth,0.08);
        \end{tikzpicture}\\[1em]
        {\usebeamerfont{section name}\usebeamercolor[fg]{section name}%
         \Large\textcolor{408blue}{第 \insertsectionnumber 模块}}\\[0.8em]
        {\usebeamerfont{section title}\usebeamercolor[fg]{section title}%
         \Huge\textcolor{408orange}{\textbf{\insertsection}}}\\[0.5em]
        \begin{tikzpicture}
            \fill[408orange] (0,0) rectangle (8,0.06);
        \end{tikzpicture}\\[1.2em]
        \begin{minipage}{0.72\textwidth}
            \small
            \tableofcontents[currentsection,hideallsubsections]
        \end{minipage}\\[1.5em]
        \begin{tikzpicture}
            \fill[408blue] (0,0) rectangle (\paperwidth,0.08);
        \end{tikzpicture}
    \end{centering}
}

% --- 课时标题页（子节） ---
\setbeamertemplate{subsection page}{
    \begin{centering}
        \vspace{1em}
        \begin{tikzpicture}
            \fill[408blue] (0,0) rectangle (\paperwidth,0.06);
        \end{tikzpicture}\\[0.8em]
        {\usebeamerfont{subsection name}\usebeamercolor[fg]{subsection name}%
         \large\textcolor{408blue}{\insertsection}}\\[0.5em]
        {\usebeamerfont{subsection title}\usebeamercolor[fg]{subsection title}%
         \LARGE\textcolor{408orange}{\textbf{\insertsubsection}}}\\[0.4em]
        \begin{tikzpicture}
            \fill[408orange] (0,0) rectangle (6,0.04);
        \end{tikzpicture}\\[1em]
        \begin{minipage}{0.65\textwidth}
            \small
            \tableofcontents[currentsubsection,hideothersubsections]
        \end{minipage}
        \vspace{1em}
    \end{centering}
}

\AtBeginSection{
    \ifbeamer@inframe\else
        \frame[plain,c]{\sectionpage}
    \fi
}

\AtBeginSubsection{
    \ifbeamer@inframe\else
        \frame[plain,c]{\subsectionpage}
    \fi
}

% --- 目录页 ---
\setbeamertemplate{section in toc}[sections numbered]
\setbeamertemplate{subsection in toc}{\leavevmode\leftskip=3.2em\inserttocsubsection\par}

% --- 超链接 ---
\usepackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=408blue,
    urlcolor=408blue
}

% --- 允许自动分页（解决页面溢出） ---
\setbeamertemplate{frametitle continuation}{}

% --- 全局字体微调 ---
\setbeamerfont{title}{size=\Large}
\setbeamerfont{subtitle}{size=\large}
\setbeamerfont{frametitle}{size=\large}
\setbeamerfont{block title}{size=\small}
