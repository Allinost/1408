\ProvidesPackage{beamer_theme_408}

% 408 考研零基础课程 Beamer 共用主题
% 使用方法: \usepackage{beamer_theme_408}

% --- 主题与配色 ---
\usetheme{Madrid}
\usecolortheme{dolphin}

% --- 支持中文 ---
\usepackage{ctex}
\usepackage{xeCJK}
\setCJKmainfont{Noto Sans CJK SC}
\setCJKsansfont{Noto Sans CJK SC}
\setCJKmonofont{Noto Sans CJK SC}
\xeCJKsetup{PunctStyle=plain}

% --- 常用数学包 ---
\usepackage{amsmath, amssymb}
\usepackage{multirow}

% --- 代码展示 ---
\usepackage{listings}
\lstset{
    basicstyle=\ttfamily\small,
    language=C,
    showstringspaces=false,
    frame=single,
    breaklines=true
}

% --- 绘图 ---
\usepackage{tikz}
\usetikzlibrary{positioning,decorations.pathreplacing,decorations.pathmorphing,shapes.geometric,arrows.meta}

% --- 颜色定义 ---
\usepackage{xcolor}
\definecolor{408blue}{RGB}{0,82,164}
\definecolor{408orange}{RGB}{230,126,34}
\definecolor{primary}{HTML}{007AFF}
\definecolor{secondary}{HTML}{5856D6}
\definecolor{accent}{HTML}{FF9500}

% --- 导航栏（顶部小节圆点） ---
\setbeamertemplate{mini frames}[box]
\setbeamertemplate{navigation symbols}{}

% --- 页脚 ---
\setbeamertemplate{footline}{
    \leavevmode
    \hbox{%
        \begin{beamercolorbox}[wd=.3\paperwidth,ht=2.5ex,dp=1ex,center]{author in head/foot}%
            \usebeamerfont{author in head/foot}\insertshorttitle
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.5\paperwidth,ht=2.5ex,dp=1ex,center]{section in head/foot}%
            \usebeamerfont{section in head/foot}\insertsectionhead
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.2\paperwidth,ht=2.5ex,dp=1ex,right]{date in head/foot}%
            \usebeamerfont{date in head/foot}\insertframenumber{} / \inserttotalframenumber\hspace*{2ex}
        \end{beamercolorbox}%
    }
    \vskip0pt
}

% --- 标题页 ---
\setbeamertemplate{title page}{
    \vfill
    \begin{centering}
        \vspace{2em}
        {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}
        \vspace{1em}
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}
        \vspace{2em}
        \begin{tikzpicture}[>=stealth]
            \node[draw,fill=408blue!10,rounded corners,inner sep=8pt] {
                \begin{minipage}{0.7\textwidth}
                    \centering
                    {\small
                    \textbf{本节要点}\\
                    路由算法概述 \quad 距离向量算法（RIP）\quad 链路状态算法（OSPF）\quad BGP边界网关协议
                    }
                \end{minipage}
            };
        \end{tikzpicture}
        \vspace{1em}
        \par
        {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate\par}
    \end{centering}
    \vfill
}

% --- 节标题页 ---
\setbeamertemplate{section page}{
    \begin{centering}
        \vspace{3em}
        {\usebeamerfont{section name}\usebeamercolor[fg]{section name}\sectionname~\insertsectionnumber\par}
        \vspace{1em}
        {\usebeamerfont{section title}\usebeamercolor[fg]{section title}\insertsection\par}
    \end{centering}
}

\AtBeginSection{
    \frame{\sectionpage}
}

% --- 目录页 ---
\setbeamertemplate{section in toc}[sections numbered]

% --- 超链接 ---
\usepackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=408blue,
    urlcolor=408blue
}
